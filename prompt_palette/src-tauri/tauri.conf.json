{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Prompt Palette",
  "version": "0.1.0",
  "identifier": "com.madis.promptpalette",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Prompt Palette",
        "width": 920,
        "height": 640,
        "minWidth": 760,
        "minHeight": 560,
        "resizable": false,
        "visible": false,
        "alwaysOnTop": true,
        "center": true,
        "maximizable": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
